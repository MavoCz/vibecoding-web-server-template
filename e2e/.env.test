# Test environment configuration
# These values are used by global-setup.ts to configure the test backend

# Dedicated test Postgres port (separate from dev port 5433)
TEST_DB_PORT=5435
TEST_DB_NAME=backend_test
TEST_DB_USER=root
TEST_DB_PASSWORD=root

# Test backend port (separate from dev port 8080)
TEST_BACKEND_PORT=8081

# Test Vite dev server port (separate from dev port 5173)
TEST_VITE_PORT=5174

# Backend source directory (relative to e2e/)
BACKEND_DIR=../backend
